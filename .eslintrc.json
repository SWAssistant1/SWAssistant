{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "webextensions": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "globals": {
    "$": "readonly",
    "jQuery": "readonly",
    "GAME": "readonly"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": "warn"
  }
}

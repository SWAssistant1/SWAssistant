{
  "name": "SW Assistant",
  "description": "Test",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.shinobiworld.pl/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.shinobiworld.pl/*"
      ],
      "run_at": "document_end",
      "js": [
        "content_script.js",
        "jquery.js"
      ]
    },
    {
      "css": [
        "custom_styles.css"
      ],
      "matches": [
        "https://*.shinobiworld.pl/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content_script1.js",
        "scripts/*.js"
      ],
      "matches": [
        "https://*.shinobiworld.pl/*"
      ]
    }
  ]
}
